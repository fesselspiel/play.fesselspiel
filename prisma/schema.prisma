generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

enum Visibility {
  PRIVATE
  PARTNER
  SHARED
}

enum ActivityStatus {
  REQUESTED
  PLANNED
  DONE
  DISCARDED
}

enum MediaKind {
  IMAGE
  VIDEO
}

enum MoodBefore {
  NEEDS_WORK
  OKAY
  NEUTRAL
  PLEASANT
  VERY_PLEASANT
}

enum MoodAfter {
  WORSE
  UNCHANGED
  SLIGHTLY_BETTER
  MUCH_BETTER
  RELAXED
}

enum TelegramChatStatus {
  PENDING
  ACTIVE
  DISABLED
}

model Tenant {
  id          String         @id @default(cuid())
  slug        String         @unique
  name        String
  headline    String?
  description String?
  disabledTitle String        @default("Dieser Bereich macht gerade Pause")
  disabledText  String        @default("Dieses Feature ist auf dieser Seite momentan nicht eingeschaltet. Falls du es erwartest, sprich kurz mit der Person, die diese Seite verwaltet. Eure vorhandenen Daten bleiben dabei erhalten.")
  disabledButtonText String   @default("Zur Startseite")
  disabledButtonHref String   @default("/")
  status      String         @default("ACTIVE")
  primaryColor String        @default("#E30613")
  homeLayout  Json           @default("[]")
  playReadyExpiryEnabled Boolean @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  domains     TenantDomain[]
  features    TenantFeature[]
  memberships TenantMembership[]
  pointRules  PointRule[]
  pointEntries PointEntry[]
  users       User[]
  circles     Circle[]
  files       FileAsset[]
  toys        Toy[]
  positions   Position[]
  catalogCategories CatalogCategory[]
  activities  ActivityPlan[]
  sessions    SegufixSession[]
  kgSessions  KgSession[]
  albums      Album[]
  media       Media[]
  events      Event[]
  apiTokens   ApiToken[]
  trackerTypes TrackerType[]
  trackerEntryImages TrackerEntryImage[]
  shopifyIntegration ShopifyIntegration?
  shopifyProducts ShopifyProduct[]
  bondageSystemItems BondageSystemItem[]
  telegramSettings TenantTelegramSettings[]
  feedRules FeedRule[]
  externalPushRules ExternalPushRule[]
  externalPushLogs ExternalPushLog[]
  nativePushSettings NativePushSettings?
  nativePushDevices NativePushDevice[]
  nativePushDeliveries NativePushDelivery[]
  nativePushNotificationRules NativePushNotificationRule[]
  chatNotificationRules ChatNotificationRule[]
  scheduledRules ScheduledRule[]
  scheduledRuleRuns ScheduledRuleRun[]
  shareDeliveries ShareDelivery[]
  playReadyLikes PlayReadyLike[]
  activityLikes ActivityLike[]
  circleChatMessages CircleChatMessage[]
  invites UserInvite[]
  packingEvents PackingEvent[]
  packingLists PackingList[]
  wikiPages WikiPage[]
  publicContentOverrides PublicContentOverride[]

  @@index([status])
}

model TenantDomain {
  id        String   @id @default(cuid())
  tenantId  String
  hostname  String   @unique
  primary   Boolean  @default(false)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, primary])
  @@index([active])
}

model TenantFeature {
  id        String   @id @default(cuid())
  tenantId  String
  key       String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([key, enabled])
}

model User {
  id                String          @id @default(cuid())
  tenantId          String?
  circleId          String?
  email             String          @unique
  username          String?         @unique
  name              String?
  passwordHash      String
  role              Role            @default(USER)
  active            Boolean         @default(true)
  emailVerifiedAt   DateTime?
  lastLoginAt       DateTime?
  rememberTokenHash String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  tenant            Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  circle            Circle?         @relation(fields: [circleId], references: [id], onDelete: SetNull)
  memberships       TenantMembership[]
  profile           Profile?
  settings          UserSettings?
  toys              Toy[]
  positions         Position[]
  activities        ActivityPlan[]
  sessions          SegufixSession[]
  kgSessions        KgSession[]
  media             Media[]
  mediaComments     MediaComment[]
  sessionComments   SessionComment[]
  albums            Album[]
  events            Event[]
  files             FileAsset[]
  sentMessages      Message[]       @relation("MessageSender")
  receivedMessages  Message[]       @relation("MessageRecipient")
  telegramChatTargets TelegramChat[] @relation("TelegramChatTargetUser")
  apiTokens         ApiToken[]
  scheduledRules    ScheduledRule[]
  sentInvites       UserInvite[] @relation("InviteCreator")
  acceptedInvites   UserInvite[] @relation("InviteAcceptedUser")
  telegramMappings  TelegramUserMapping[] @relation("TelegramMappedAppUser")
  telegramNotificationTargets TelegramNotificationRule[] @relation("TelegramNotificationTargetUser")
  emailNotificationTargets EmailNotificationRule[] @relation("EmailNotificationTargetUser")
  tenantTelegramBots TenantTelegramSettings[] @relation("TenantTelegramBotOwner")
  auditLogs         AuditLog[]
  feedComments      FeedComment[]
  feedLikes         FeedLike[]
  feedDismissals    FeedDismissal[]
  pointEntries      PointEntry[]
  activityLikes     ActivityLike[]
  activityComments  ActivityComment[]
  trackerEntries    TrackerEntry[]
  favoriteToys      ToyFavorite[]
  favoritePositions PositionFavorite[]
  playReadyLikesGiven PlayReadyLike[] @relation("PlayReadyLikeActor")
  playReadyLikesReceived PlayReadyLike[] @relation("PlayReadyLikeTarget")
  bondageSystemTargets BondageSystemItem[] @relation("BondageSystemTargetUser")
  emailConfirmationTokens EmailConfirmationToken[]
  passwordResetTokens PasswordResetToken[]
  nativePushDevices NativePushDevice[]
  nativePushDeliveries NativePushDelivery[]
  nativePushNotificationTargets NativePushNotificationRule[] @relation("NativePushNotificationTargetUser")
  shareDeliveriesSent ShareDelivery[] @relation("ShareDeliveryActor")
  shareDeliveriesReceived ShareDelivery[] @relation("ShareDeliveryTargetUser")
  circleChatMessages CircleChatMessage[] @relation("CircleChatSender")
  circleChatReceipts CircleChatReceipt[]
  packingEvents PackingEvent[]
  packingLists PackingList[]
  packedItems PackingListItem[] @relation("PackingItemPackedBy")
  wikiPages WikiPage[]
  wikiPageShares WikiPageShare[]
  wikiPageRevisions WikiPageRevision[]
  publicContentOverrides PublicContentOverride[]

  @@index([tenantId])
  @@index([circleId])
}

model TenantMembership {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  circleId  String?
  role      Role     @default(USER)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  circle    Circle?  @relation(fields: [circleId], references: [id], onDelete: SetNull)

  @@unique([tenantId, userId])
  @@index([tenantId, role, active])
  @@index([circleId])
  @@index([userId])
}

model EmailConfirmationToken {
  id        String    @id @default(cuid())
  userId    String
  email     String?
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
  @@index([email])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
  @@index([expiresAt])
}

model Circle {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users     User[]
  memberships TenantMembership[]
  telegramChatTargets TelegramChat[] @relation("TelegramChatTargetCircle")
  telegramNotificationTargets TelegramNotificationRule[] @relation("TelegramNotificationTargetCircle")
  emailNotificationTargets EmailNotificationRule[] @relation("EmailNotificationTargetCircle")
  nativePushNotificationTargets NativePushNotificationRule[] @relation("NativePushNotificationTargetCircle")
  chatNotificationTargets ChatNotificationRule[] @relation("ChatNotificationTargetCircle")
  bondageSystemTargets BondageSystemItem[] @relation("BondageSystemTargetCircle")
  chatMessages CircleChatMessage[]
  wikiPageShares WikiPageShare[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model FileAsset {
  id           String   @id @default(cuid())
  tenantId     String?
  ownerId      String
  originalName String
  mimeType     String
  sizeBytes    Int
  storagePath  String
  createdAt    DateTime @default(now())
  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner        User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  activityImages ActivityImage[]
  trackerEntryImages TrackerEntryImage[]
  circleChatMessages CircleChatMessage[]
  wikiImages WikiPageImage[]

  @@index([tenantId, ownerId, createdAt])
  @@index([ownerId, createdAt])
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  displayName String?
  bio       String?
  imageUrl  String?
  fields    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSettings {
  id                  String         @id @default(cuid())
  userId              String         @unique
  theme               String         @default("red")
  darkMode            Boolean        @default(false)
  playReady           Boolean        @default(false)
  playReadyState      String         @default("red")
  playReadyUpdatedAt  DateTime?
  playReadyExpiresAt  DateTime?
  playReadyExpiryMinutes Int?           @default(360)
  shareDefaultChannel String            @default("all")
  shareMessageTemplate String           @default("Schau dir das an: {title}\n{url}")
  inviteQuota         Int            @default(3)
  timeOffsetMinutes   Int            @default(0)
  telegramBotTokenEnc String?
  openAiApiKeyEnc     String?
  telegramChats       TelegramChat[]
  telegramUserMappings TelegramUserMapping[]
  telegramKnownUsers  TelegramKnownUser[]
  telegramNotificationRules TelegramNotificationRule[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserInvite {
  id              String    @id @default(cuid())
  tenantId        String
  invitedById     String
  acceptedById    String?
  email           String?
  name            String?
  tokenHash       String    @unique
  tokenEnc        String?
  status          String    @default("OPEN")
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy       User      @relation("InviteCreator", fields: [invitedById], references: [id], onDelete: Cascade)
  acceptedBy      User?     @relation("InviteAcceptedUser", fields: [acceptedById], references: [id], onDelete: SetNull)

  @@index([tenantId, status, createdAt])
  @@index([invitedById, createdAt])
  @@index([acceptedById])
  @@index([expiresAt])
}

model TenantTelegramSettings {
  id                  String         @id @default(cuid())
  tenantId            String
  ownerId             String?
  key                 String         @default("default")
  name                String         @default("Standard-Bot")
  scope               String         @default("TENANT")
  active              Boolean        @default(true)
  isDefault           Boolean        @default(false)
  telegramBotTokenEnc String?
  openAiApiKeyEnc     String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  tenant              Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner               User?          @relation("TenantTelegramBotOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  telegramChats       TelegramChat[]
  telegramUserMappings TelegramUserMapping[]
  telegramKnownUsers  TelegramKnownUser[]
  telegramNotificationRules TelegramNotificationRule[]

  @@unique([tenantId, key])
  @@index([tenantId, scope, active])
  @@index([ownerId])
}

model ApiToken {
  id           String    @id @default(cuid())
  tenantId     String?
  userId       String
  name         String
  tokenHash    String    @unique
  tokenLastSix String
  active       Boolean   @default(true)
  lastUsedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  tenant       Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, active])
  @@index([userId, active])
}

model ExternalViewContext {
  id          String    @id @default(cuid())
  tokenId     String
  actorId     String
  tenantId    String?
  userId      String?
  mode        String
  contextHash String    @unique
  expiresAt   DateTime
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([tokenId, expiresAt])
  @@index([actorId, createdAt])
  @@index([tenantId])
  @@index([userId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String?
  entityId   String?
  title      String
  details    Json?
  href       String?
  createdAt  DateTime @default(now())
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  feedComments FeedComment[]
  feedLikes     FeedLike[]
  feedDismissals FeedDismissal[]
  pointEntries  PointEntry[]

  @@index([actorId, createdAt])
  @@index([createdAt])
  @@index([entityType, entityId])
}

model PointRule {
  id        String   @id @default(cuid())
  tenantId  String
  action    String
  points    Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, action])
  @@index([tenantId, active])
  @@index([action])
}

model PointEntry {
  id         String    @id @default(cuid())
  tenantId   String
  userId     String
  auditLogId String?
  action     String
  points     Int
  note       String?
  createdAt  DateTime  @default(now())
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditLog   AuditLog? @relation(fields: [auditLogId], references: [id], onDelete: SetNull)

  @@unique([auditLogId, userId])
  @@index([tenantId, createdAt])
  @@index([tenantId, userId, createdAt])
  @@index([tenantId, action, createdAt])
}

model FeedComment {
  id        String   @id @default(cuid())
  auditLogId String
  authorId  String?
  body      String
  createdAt DateTime @default(now())
  auditLog  AuditLog @relation(fields: [auditLogId], references: [id], onDelete: Cascade)
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([auditLogId, createdAt])
  @@index([authorId, createdAt])
}

model FeedLike {
  id        String   @id @default(cuid())
  auditLogId String
  userId    String?
  createdAt DateTime @default(now())
  auditLog  AuditLog @relation(fields: [auditLogId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([auditLogId, userId])
  @@index([auditLogId, createdAt])
  @@index([userId, createdAt])
}

model FeedDismissal {
  id         String   @id @default(cuid())
  auditLogId String
  userId     String
  createdAt  DateTime @default(now())
  auditLog   AuditLog @relation(fields: [auditLogId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([auditLogId, userId])
  @@index([auditLogId, createdAt])
  @@index([userId, createdAt])
}

model FeedRule {
  id            String   @id @default(cuid())
  tenantId      String
  action        String
  titleTemplate String   @default("{title}")
  bodyTemplate  String   @default("{actor} · {event}")
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, action])
  @@index([tenantId, active])
  @@index([action])
}

model PlayReadyLike {
  id           String   @id @default(cuid())
  tenantId     String?
  actorId      String
  targetUserId String
  createdAt    DateTime @default(now())
  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor        User     @relation("PlayReadyLikeActor", fields: [actorId], references: [id], onDelete: Cascade)
  targetUser   User     @relation("PlayReadyLikeTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@unique([tenantId, actorId, targetUserId])
  @@index([targetUserId, createdAt])
  @@index([actorId, createdAt])
}

model ActivityLike {
  id         String       @id @default(cuid())
  tenantId   String?
  activityId String
  userId     String?
  createdAt  DateTime     @default(now())
  activity   ActivityPlan @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user       User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  tenant     Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([activityId, userId])
  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
}

model ExternalPushRule {
  id             String   @id @default(cuid())
  tenantId       String
  action         String
  name           String
  url            String
  method         String   @default("POST")
  headersJson    Json     @default("{}")
  payloadTemplate String  @default("{\"title\":\"{title}\",\"event\":\"{event}\",\"actor\":\"{actor}\",\"url\":\"{url}\",\"details\":{detailsJson}}")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, action, active])
}

model ExternalPushLog {
  id         String   @id @default(cuid())
  tenantId   String?
  ruleId     String?
  action     String
  url        String
  status     String
  statusCode Int?
  error      String?
  createdAt  DateTime @default(now())
  tenant     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([action, createdAt])
  @@index([status, createdAt])
}

model NativePushSettings {
  id                       String   @id @default(cuid())
  tenantId                 String   @unique
  enabled                  Boolean  @default(false)
  teamId                   String?
  keyId                    String?
  bundleId                 String   @default("fspiel.playplaner")
  privateKeyEnc            String?
  environment              String   @default("production")
  fcmProjectId             String?
  fcmServiceAccountJsonEnc String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  tenant                   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([enabled])
}

model NativePushDevice {
  id          String    @id @default(cuid())
  tenantId    String?
  userId      String
  platform    String
  deviceToken String
  environment String   @default("production")
  deviceName  String?
  appVersion  String?
  lastSeenAt  DateTime @default(now())
  disabledAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries  NativePushDelivery[]

  @@unique([platform, deviceToken])
  @@index([tenantId, userId, disabledAt])
  @@index([userId, lastSeenAt])
}

model NativePushDelivery {
  id          String    @id @default(cuid())
  tenantId    String?
  userId      String
  deviceId    String?
  auditId     String?
  action      String
  status      String
  apnsId      String?
  statusCode  Int?
  error       String?
  payload     Json?
  createdAt   DateTime  @default(now())
  tenant      Tenant?    @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  device      NativePushDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([auditId])
  @@index([action, status, createdAt])
}

model NativePushNotificationRule {
  id             String   @id @default(cuid())
  tenantId       String
  action         String
  targetAll      Boolean  @default(false)
  targetUserId   String?
  targetCircleId String?
  titleTemplate  String   @default("{event}")
  bodyTemplate   String   @default("{title}")
  sound          String   @default("playplaner_chime.caf")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  targetUser     User?    @relation("NativePushNotificationTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetCircle   Circle?  @relation("NativePushNotificationTargetCircle", fields: [targetCircleId], references: [id], onDelete: SetNull)

  @@index([tenantId, action, active])
  @@index([targetUserId])
  @@index([targetCircleId])
}

model ShareDelivery {
  id           String    @id @default(cuid())
  token        String    @unique
  tenantId     String?
  actorId      String
  targetUserId String
  channel      String
  entityType   String
  entityId     String
  title        String
  href         String
  text         String?
  openCount    Int       @default(0)
  openedAt     DateTime?
  lastOpenedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  tenant       Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor        User      @relation("ShareDeliveryActor", fields: [actorId], references: [id], onDelete: Cascade)
  targetUser   User      @relation("ShareDeliveryTargetUser", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([actorId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([channel, openedAt])
}

model ScheduledRule {
  id               String   @id @default(cuid())
  tenantId         String
  ownerId          String
  name             String
  active           Boolean  @default(true)
  scheduleType     String   @default("DAILY")
  timeOfDayMinutes Int      @default(960)
  daysOfWeek       Int[]    @default([])
  dayOfMonth       Int?
  intervalMinutes  Int?
  timezone         String   @default("Europe/Berlin")
  conditionType    String   @default("ALWAYS")
  conditionJson    Json     @default("{}")
  actionType       String   @default("EXTERNAL_URL")
  actionJson       Json     @default("{}")
  nextRunAt        DateTime?
  lastRunAt        DateTime?
  lastStatus       String?
  lastMessage      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner            User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  runs             ScheduledRuleRun[]

  @@index([tenantId, active, nextRunAt])
  @@index([ownerId, active])
}

model ScheduledRuleRun {
  id           String   @id @default(cuid())
  tenantId     String
  ruleId       String
  status       String
  conditionMet Boolean  @default(false)
  message      String?
  details      Json?
  createdAt    DateTime @default(now())
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rule         ScheduledRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([ruleId, createdAt])
  @@index([status, createdAt])
}

model EmailSettings {
  id        String   @id @default("system")
  enabled   Boolean  @default(false)
  fromName  String   @default("Fesselspiel")
  fromEmail String   @default("no-reply@playplaner.com")
  smtpHost  String   @default("postfix")
  smtpPort  Int      @default(25)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailTemplate {
  id        String   @id @default(cuid())
  key       String   @unique
  title     String
  subject   String
  body      String
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  notificationRules EmailNotificationRule[]

  @@index([enabled])
}

model EmailLog {
  id          String   @id @default(cuid())
  templateKey String?
  recipient   String
  subject     String
  status      String
  fromEmail   String?
  fromName    String?
  smtpHost    String?
  smtpPort    Int?
  messageId   String?
  details     Json?
  error       String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([templateKey, createdAt])
  @@index([status, createdAt])
}

model EmailNotificationRule {
  id             String        @id @default(cuid())
  action         String
  targetUserId   String?
  targetCircleId String?
  templateKey    String
  active         Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  targetUser     User?         @relation("EmailNotificationTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetCircle   Circle?       @relation("EmailNotificationTargetCircle", fields: [targetCircleId], references: [id], onDelete: SetNull)
  template       EmailTemplate @relation(fields: [templateKey], references: [key], onDelete: Cascade)

  @@index([action, active])
  @@index([targetUserId])
  @@index([targetCircleId])
  @@index([templateKey])
}

model Toy {
  id          String         @id @default(cuid())
  tenantId    String?
  categoryId  String?
  ownerId     String
  title       String
  slug        String
  description String?
  imageUrl    String?
  sourceTenantId String?
  sourceToyId String?
  selfBondageCapable Boolean @default(false)
  sortOrder   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  tenant      Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category    CatalogCategory? @relation("ToyCategory", fields: [categoryId], references: [id], onDelete: SetNull)
  owner       User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  positions   Position[]     @relation("PositionTools")
  activities  ActivityPlan[] @relation("ActivityTools")
  trackerEntries TrackerEntry[] @relation("TrackerEntryToys")
  favorites   ToyFavorite[]
  packingItems PackingListItem[]

  @@unique([tenantId, slug])
  @@index([tenantId, sourceToyId])
  @@index([sourceTenantId])
  @@index([categoryId, sortOrder, title])
  @@index([tenantId, sortOrder, title])
  @@index([ownerId, sortOrder, title])
}

model ToyFavorite {
  id        String   @id @default(cuid())
  toyId     String
  userId    String
  createdAt DateTime @default(now())
  toy       Toy      @relation(fields: [toyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([toyId, userId])
  @@index([userId, createdAt])
  @@index([toyId, createdAt])
}

model Position {
  id          String         @id @default(cuid())
  tenantId    String?
  categoryId  String?
  ownerId     String
  name        String
  slug        String
  description String?
  imageUrl    String?
  sourceTenantId String?
  sourcePositionId String?
  selfBondageCapable Boolean @default(false)
  sortOrder   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  tenant      Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category    CatalogCategory? @relation("PositionCategory", fields: [categoryId], references: [id], onDelete: SetNull)
  owner       User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tools       Toy[]          @relation("PositionTools")
  bondageSystemItems BondageSystemItem[] @relation("PositionBondageSystemItems")
  activities  ActivityPlan[] @relation("ActivityPositions")
  trackerEntries TrackerEntry[] @relation("TrackerEntryPositions")
  favorites   PositionFavorite[]

  @@unique([tenantId, slug])
  @@index([tenantId, sourcePositionId])
  @@index([sourceTenantId])
  @@index([categoryId, sortOrder, name])
  @@index([tenantId, sortOrder, name])
  @@index([ownerId, sortOrder, name])
}

model CatalogCategory {
  id        String   @id @default(cuid())
  tenantId  String?
  kind      String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  toys      Toy[]    @relation("ToyCategory")
  positions Position[] @relation("PositionCategory")

  @@unique([tenantId, kind, name])
  @@index([tenantId, kind, sortOrder, name])
}

model PositionFavorite {
  id         String   @id @default(cuid())
  positionId String
  userId     String
  createdAt  DateTime @default(now())
  position   Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([positionId, userId])
  @@index([userId, createdAt])
  @@index([positionId, createdAt])
}

model WikiPage {
  id          String   @id @default(cuid())
  tenantId    String?
  ownerId     String
  title       String
  slug        String
  summary     String?
  content     String   @default("")
  visibility  Visibility @default(PRIVATE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  shares      WikiPageShare[]
  revisions   WikiPageRevision[]
  images      WikiPageImage[]

  @@unique([tenantId, ownerId, slug])
  @@index([tenantId, ownerId, updatedAt])
  @@index([ownerId, updatedAt])
  @@index([visibility])
}

model PublicContentOverride {
  id          String   @id @default(cuid())
  tenantId    String
  key         String
  value       Json
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  updatedBy   User?    @relation(fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([tenantId, key])
  @@index([tenantId, updatedAt])
  @@index([updatedById])
}

model WikiPageRevision {
  id        String   @id @default(cuid())
  pageId    String
  actorId   String?
  title     String
  slug      String
  summary   String?
  content   String
  action    String   @default("updated")
  createdAt DateTime @default(now())
  page      WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([pageId, createdAt])
  @@index([actorId, createdAt])
}

model WikiPageImage {
  id        String   @id @default(cuid())
  pageId    String
  fileId    String
  title     String?
  createdAt DateTime @default(now())
  page      WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  file      FileAsset @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([pageId, createdAt])
  @@index([fileId])
}

model WikiPageShare {
  id             String   @id @default(cuid())
  pageId         String
  targetUserId   String?
  targetCircleId String?
  createdAt      DateTime @default(now())
  page           WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  targetUser     User?    @relation(fields: [targetUserId], references: [id], onDelete: Cascade)
  targetCircle   Circle?  @relation(fields: [targetCircleId], references: [id], onDelete: Cascade)

  @@unique([pageId, targetUserId])
  @@unique([pageId, targetCircleId])
  @@index([targetUserId])
  @@index([targetCircleId])
}

model ActivityPlan {
  id          String         @id @default(cuid())
  tenantId    String?
  ownerId     String
  title       String
  slug        String
  category    String?
  note        String?
  plannedAt   DateTime?
  status      ActivityStatus @default(PLANNED)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  tenant      Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner       User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tools       Toy[]          @relation("ActivityTools")
  bondageSystemItems BondageSystemItem[] @relation("ActivityBondageSystemItems")
  positions   Position[]     @relation("ActivityPositions")
  media       Media[]
  images      ActivityImage[]
  likes       ActivityLike[]
  comments    ActivityComment[]

  @@unique([tenantId, slug])
  @@index([tenantId, status, plannedAt])
  @@index([ownerId, status, plannedAt])
}

model ActivityComment {
  id         String       @id @default(cuid())
  activityId String
  ownerId    String
  body       String
  createdAt  DateTime     @default(now())
  activity   ActivityPlan @relation(fields: [activityId], references: [id], onDelete: Cascade)
  owner      User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([activityId, createdAt])
  @@index([ownerId, createdAt])
}

model ShopifyIntegration {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  shopDomain      String
  clientIdEnc     String?
  clientSecretEnc String?
  accessTokenEnc  String?
  accessTokenExpiresAt DateTime?
  accessTokenScope String?
  apiVersion      String   @default("2026-04")
  productTag      String
  enabled         Boolean  @default(true)
  lastSyncAt      DateTime?
  lastSyncStatus  String?
  lastSyncMessage String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([enabled])
}

model ShopifyProduct {
  id               String   @id @default(cuid())
  tenantId         String
  shopifyProductId String
  title            String
  slug             String
  handle           String
  description      String?
  imageUrl         String?
  productUrl       String?
  vendor           String?
  tags             String[] @default([])
  inTagFilter      Boolean  @default(true)
  lastSyncedAt     DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bondageSystemItem BondageSystemItem?

  @@unique([tenantId, shopifyProductId])
  @@unique([tenantId, slug])
  @@index([tenantId, inTagFilter, title])
}

model BondageSystemItem {
  id               String     @id @default(cuid())
  tenantId         String
  shopifyProductId String     @unique
  visible          Boolean    @default(false)
  visibility       Visibility @default(PRIVATE)
  targetUserId     String?
  targetCircleId   String?
  sortOrder        Int        @default(0)
  showExternalLink Boolean    @default(false)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  tenant           Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product          ShopifyProduct @relation(fields: [shopifyProductId], references: [id], onDelete: Cascade)
  targetUser       User?      @relation("BondageSystemTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetCircle     Circle?    @relation("BondageSystemTargetCircle", fields: [targetCircleId], references: [id], onDelete: SetNull)
  positions        Position[] @relation("PositionBondageSystemItems")
  activities       ActivityPlan[] @relation("ActivityBondageSystemItems")
  trackerEntries   TrackerEntry[] @relation("TrackerEntryBondageSystemItems")

  @@index([tenantId, visible, sortOrder])
  @@index([targetUserId])
  @@index([targetCircleId])
}

model ActivityImage {
  id         String       @id @default(cuid())
  activityId String
  fileId     String
  title      String
  createdAt  DateTime     @default(now())
  activity   ActivityPlan @relation(fields: [activityId], references: [id], onDelete: Cascade)
  file       FileAsset    @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([activityId, createdAt])
  @@index([fileId])
}

model SegufixSession {
  id             String      @id @default(cuid())
  tenantId       String?
  ownerId        String
  slug           String?
  startTime      DateTime
  endTime        DateTime?
  durationMinutes Int?
  notes          String?
  moodBefore     MoodBefore?
  moodBeforeText String?
  moodAfter      MoodAfter?
  moodAfterText  String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  tenant         Tenant?     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner          User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  media          Media[]
  comments       SessionComment[]

  @@unique([tenantId, slug])
  @@index([tenantId, startTime])
  @@index([ownerId, startTime])
  @@index([slug])
}

model TrackerType {
  id                    String         @id @default(cuid())
  tenantId              String?
  key                   String
  title                 String
  description           String?
  color                 String         @default("#E30613")
  icon                  String?
  enabled               Boolean        @default(true)
  allowOpenSession      Boolean        @default(true)
  autoCloseOpenSession  Boolean        @default(true)
  quotaDailyMinutes     Int?
  quotaWeeklyMinutes    Int?
  quotaWeeklyTail       Boolean        @default(false)
  quotaWeekStartsOn     Int            @default(1)
  quotaMonthlyDays      Int?
  quotaMonthlyMinutes   Int?
  quotaReminderEnabled  Boolean        @default(false)
  fields                Json           @default("[]")
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  tenant                Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entries               TrackerEntry[]

  @@unique([tenantId, key])
  @@index([tenantId, enabled])
}

model TrackerEntry {
  id              String      @id @default(cuid())
  tenantId        String?
  ownerId         String
  trackerTypeId   String
  legacyType      String?
  legacyId        String?
  slug            String?
  title           String?
  startTime       DateTime
  endTime         DateTime?
  allDay          Boolean     @default(false)
  durationMinutes Int?
  notes           String?
  fieldValues     Json        @default("{}")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  owner           User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  trackerType     TrackerType @relation(fields: [trackerTypeId], references: [id], onDelete: Cascade)
  toys            Toy[]       @relation("TrackerEntryToys")
  bondageSystemItems BondageSystemItem[] @relation("TrackerEntryBondageSystemItems")
  positions       Position[]  @relation("TrackerEntryPositions")
  images          TrackerEntryImage[]

  @@unique([trackerTypeId, legacyType, legacyId])
  @@unique([tenantId, trackerTypeId, slug])
  @@index([ownerId, startTime])
  @@index([tenantId, trackerTypeId, startTime])
}

model TrackerEntryImage {
  id             String       @id @default(cuid())
  tenantId       String?
  trackerEntryId String
  fileId         String
  title          String?
  note           String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  tenant         Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  trackerEntry   TrackerEntry @relation(fields: [trackerEntryId], references: [id], onDelete: Cascade)
  file           FileAsset    @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([tenantId, trackerEntryId, createdAt])
  @@index([trackerEntryId, createdAt])
  @@index([fileId])
}

model KgSession {
  id              String   @id @default(cuid())
  tenantId        String?
  ownerId         String
  startTime       DateTime
  endTime         DateTime?
  durationMinutes Int?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner           User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([tenantId, startTime])
  @@index([ownerId, startTime])
}

model Album {
  id          String     @id @default(cuid())
  tenantId    String?
  ownerId     String
  title       String
  description String?
  coverMediaId String?
  visibility  Visibility @default(PRIVATE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tenant      Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner       User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  media       Media[]

  @@index([coverMediaId])
  @@index([tenantId, ownerId])
}

model Media {
  id          String     @id @default(cuid())
  tenantId    String?
  ownerId     String
  albumId     String?
  sessionId   String?
  activityId  String?
  showInCalendar Boolean @default(false)
  calendarDate DateTime?
  title       String
  kind        MediaKind
  url         String
  visibility  Visibility?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tenant      Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner       User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  album       Album?     @relation(fields: [albumId], references: [id], onDelete: SetNull)
  session     SegufixSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  activity    ActivityPlan? @relation(fields: [activityId], references: [id], onDelete: Cascade)
  comments    MediaComment[]

  @@index([sessionId])
  @@index([activityId])
  @@index([tenantId, showInCalendar, calendarDate])
  @@index([tenantId, ownerId, createdAt])
}

model MediaComment {
  id        String   @id @default(cuid())
  mediaId   String
  ownerId   String
  body      String
  createdAt DateTime @default(now())
  media     Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([mediaId, createdAt])
  @@index([ownerId, createdAt])
}

model SessionComment {
  id        String         @id @default(cuid())
  sessionId String
  ownerId   String
  body      String
  createdAt DateTime       @default(now())
  session   SegufixSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  owner     User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([ownerId, createdAt])
}

model Event {
  id          String    @id @default(cuid())
  tenantId    String?
  ownerId     String
  title       String
  location    String?
  startsAt    DateTime
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenant      Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner       User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  checkIns    CheckIn[]
  packingEvents PackingEvent[]
  packingLists PackingList[]

  @@index([tenantId, startsAt])
}

model PackingEvent {
  id          String     @id @default(cuid())
  tenantId    String?
  ownerId     String
  eventId     String?
  title       String
  slug        String
  description String?
  location    String?
  startsAt    DateTime?
  visibility  Visibility @default(PARTNER)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tenant      Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner       User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  event       Event?     @relation(fields: [eventId], references: [id], onDelete: SetNull)
  lists       PackingList[]

  @@unique([tenantId, slug])
  @@index([tenantId, startsAt])
  @@index([ownerId, startsAt])
  @@index([eventId])
}

model PackingList {
  id          String     @id @default(cuid())
  tenantId    String?
  ownerId     String
  packingEventId String?
  eventId     String?
  title       String
  slug        String
  note        String?
  visibility  Visibility @default(PARTNER)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tenant      Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner       User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  packingEvent PackingEvent? @relation(fields: [packingEventId], references: [id], onDelete: SetNull)
  event       Event?     @relation(fields: [eventId], references: [id], onDelete: SetNull)
  items       PackingListItem[]

  @@unique([tenantId, slug])
  @@index([tenantId, sortOrder, title])
  @@index([ownerId, sortOrder, title])
  @@index([packingEventId])
  @@index([eventId])
}

model PackingListItem {
  id          String   @id @default(cuid())
  listId      String
  toyId       String
  note        String?
  quantity    Int      @default(1)
  packed      Boolean  @default(false)
  packedAt    DateTime?
  packedById  String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  list        PackingList @relation(fields: [listId], references: [id], onDelete: Cascade)
  toy         Toy      @relation(fields: [toyId], references: [id], onDelete: Cascade)
  packedBy    User?    @relation("PackingItemPackedBy", fields: [packedById], references: [id], onDelete: SetNull)

  @@unique([listId, toyId])
  @@index([listId, sortOrder])
  @@index([toyId])
  @@index([packedById])
}

model CheckIn {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  note      String?
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model Message {
  id          String    @id @default(cuid())
  senderId    String
  recipientId String?
  body        String
  mediaUrl    String?
  createdAt   DateTime  @default(now())
  sender      User      @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient   User?     @relation("MessageRecipient", fields: [recipientId], references: [id], onDelete: SetNull)
}

model CircleChatMessage {
  id          String    @id @default(cuid())
  tenantId    String
  circleId    String
  senderId    String
  body        String?
  fileId      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  circle      Circle    @relation(fields: [circleId], references: [id], onDelete: Cascade)
  sender      User      @relation("CircleChatSender", fields: [senderId], references: [id], onDelete: Cascade)
  file        FileAsset? @relation(fields: [fileId], references: [id], onDelete: SetNull)
  receipts    CircleChatReceipt[]

  @@index([tenantId, circleId, createdAt])
  @@index([senderId, createdAt])
  @@index([fileId])
}

model CircleChatReceipt {
  id          String    @id @default(cuid())
  messageId   String
  userId      String
  deliveredAt DateTime?
  readAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  message     CircleChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, readAt])
  @@index([messageId, readAt])
}

model ChatNotificationRule {
  id             String   @id @default(cuid())
  tenantId       String
  action         String
  targetCircleId String
  message        String   @default("{actor}: {event}\n{title}\n{url}")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  targetCircle   Circle   @relation("ChatNotificationTargetCircle", fields: [targetCircleId], references: [id], onDelete: Cascade)

  @@index([tenantId, action, active])
  @@index([targetCircleId])
}

model TelegramChat {
  id              String             @id @default(cuid())
  settingsId      String
  telegramSettingsId String?
  targetUserId    String?
  targetCircleId  String?
  chatId          String
  threadId        String?
  chatType        String?
  title           String?
  chatTitle       String?
  threadTitle     String?
  status          TelegramChatStatus @default(PENDING)
  lastMessageText String?
  lastMessageFrom String?
  lastMessageAt   DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  settings        UserSettings       @relation(fields: [settingsId], references: [id], onDelete: Cascade)
  telegramSettings TenantTelegramSettings? @relation(fields: [telegramSettingsId], references: [id], onDelete: Cascade)
  targetUser      User?              @relation("TelegramChatTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetCircle    Circle?            @relation("TelegramChatTargetCircle", fields: [targetCircleId], references: [id], onDelete: SetNull)
  notificationRules TelegramNotificationRule[] @relation("TelegramNotificationOutputChat")

  @@unique([settingsId, chatId, threadId])
  @@unique([telegramSettingsId, chatId, threadId])
  @@index([telegramSettingsId])
  @@index([targetUserId])
  @@index([targetCircleId])
}

model TelegramUserMapping {
  id               String       @id @default(cuid())
  settingsId       String?
  telegramSettingsId String?
  telegramUsername String
  telegramUserId   String?
  appUserId        String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  settings         UserSettings? @relation(fields: [settingsId], references: [id], onDelete: Cascade)
  telegramSettings TenantTelegramSettings? @relation(fields: [telegramSettingsId], references: [id], onDelete: Cascade)
  appUser          User         @relation("TelegramMappedAppUser", fields: [appUserId], references: [id], onDelete: Cascade)

  @@unique([settingsId, telegramUsername])
  @@unique([telegramSettingsId, telegramUsername])
  @@index([telegramSettingsId, telegramUserId])
  @@index([settingsId, telegramUserId])
  @@index([appUserId])
}

model TelegramKnownUser {
  id               String       @id @default(cuid())
  settingsId       String?
  telegramSettingsId String?
  telegramUserId   String
  telegramUsername String?
  firstName        String?
  lastName         String?
  membershipStatus String       @default("ACTIVE")
  source           String       @default("MESSAGE")
  lastChatId       String?
  lastChatTitle    String?
  lastMessageAt    DateTime     @default(now())
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  settings         UserSettings? @relation(fields: [settingsId], references: [id], onDelete: Cascade)
  telegramSettings TenantTelegramSettings? @relation(fields: [telegramSettingsId], references: [id], onDelete: Cascade)

  @@unique([settingsId, telegramUserId])
  @@unique([telegramSettingsId, telegramUserId])
  @@index([telegramSettingsId, telegramUsername])
  @@index([telegramSettingsId, membershipStatus])
  @@index([settingsId, telegramUsername])
  @@index([settingsId, membershipStatus])
}

model TelegramNotificationRule {
  id             String       @id @default(cuid())
  settingsId     String
  telegramSettingsId String?
  action         String
  targetUserId   String?
  targetCircleId String?
  outputChatId   String?
  message        String
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  settings       UserSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)
  telegramSettings TenantTelegramSettings? @relation(fields: [telegramSettingsId], references: [id], onDelete: Cascade)
  targetUser     User?        @relation("TelegramNotificationTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetCircle   Circle?      @relation("TelegramNotificationTargetCircle", fields: [targetCircleId], references: [id], onDelete: SetNull)
  outputChat     TelegramChat? @relation("TelegramNotificationOutputChat", fields: [outputChatId], references: [id], onDelete: SetNull)

  @@index([settingsId, action, active])
  @@index([telegramSettingsId, action, active])
  @@index([targetUserId])
  @@index([targetCircleId])
  @@index([outputChatId])
}

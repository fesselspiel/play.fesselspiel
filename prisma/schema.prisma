generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum Visibility {
  PRIVATE
  PARTNER
  SHARED
}

enum ActivityStatus {
  PLANNED
  DONE
  DISCARDED
}

enum MediaKind {
  IMAGE
  VIDEO
}

enum MoodBefore {
  NEEDS_WORK
  OKAY
  NEUTRAL
  PLEASANT
  VERY_PLEASANT
}

enum MoodAfter {
  WORSE
  UNCHANGED
  SLIGHTLY_BETTER
  MUCH_BETTER
  RELAXED
}

enum TelegramChatStatus {
  PENDING
  ACTIVE
  DISABLED
}

model User {
  id                String          @id @default(cuid())
  circleId          String?
  email             String          @unique
  username          String?         @unique
  name              String?
  passwordHash      String
  role              Role            @default(USER)
  active            Boolean         @default(true)
  rememberTokenHash String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  circle            Circle?         @relation(fields: [circleId], references: [id], onDelete: SetNull)
  profile           Profile?
  settings          UserSettings?
  toys              Toy[]
  positions         Position[]
  activities        ActivityPlan[]
  sessions          SegufixSession[]
  media             Media[]
  mediaComments     MediaComment[]
  sessionComments   SessionComment[]
  albums            Album[]
  events            Event[]
  files             FileAsset[]
  sentMessages      Message[]       @relation("MessageSender")
  receivedMessages  Message[]       @relation("MessageRecipient")
  telegramChatTargets TelegramChat[] @relation("TelegramChatTargetUser")
  apiTokens         ApiToken[]
  telegramMappings  TelegramUserMapping[] @relation("TelegramMappedAppUser")

  @@index([circleId])
}

model Circle {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  telegramChatTargets TelegramChat[] @relation("TelegramChatTargetCircle")
}

model FileAsset {
  id           String   @id @default(cuid())
  ownerId      String
  originalName String
  mimeType     String
  sizeBytes    Int
  storagePath  String
  createdAt    DateTime @default(now())
  owner        User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, createdAt])
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  displayName String?
  bio       String?
  fields    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSettings {
  id                  String         @id @default(cuid())
  userId              String         @unique
  theme               String         @default("red")
  darkMode            Boolean        @default(false)
  playReady           Boolean        @default(false)
  playReadyUpdatedAt  DateTime?
  telegramBotTokenEnc String?
  openAiApiKeyEnc     String?
  telegramChats       TelegramChat[]
  telegramUserMappings TelegramUserMapping[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApiToken {
  id           String    @id @default(cuid())
  userId       String
  name         String
  tokenHash    String    @unique
  tokenLastSix String
  active       Boolean   @default(true)
  lastUsedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, active])
}

model Toy {
  id          String         @id @default(cuid())
  ownerId     String
  title       String
  slug        String         @unique
  description String?
  imageUrl    String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  owner       User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  positions   Position[]     @relation("PositionTools")
  activities  ActivityPlan[] @relation("ActivityTools")

  @@index([ownerId, title])
}

model Position {
  id          String         @id @default(cuid())
  ownerId     String
  name        String
  slug        String         @unique
  description String?
  imageUrl    String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  owner       User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tools       Toy[]          @relation("PositionTools")
  activities  ActivityPlan[] @relation("ActivityPositions")

  @@index([ownerId, name])
}

model ActivityPlan {
  id          String         @id @default(cuid())
  ownerId     String
  title       String
  slug        String         @unique
  category    String?
  note        String?
  plannedAt   DateTime?
  status      ActivityStatus @default(PLANNED)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  owner       User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tools       Toy[]          @relation("ActivityTools")
  positions   Position[]     @relation("ActivityPositions")

  @@index([ownerId, status, plannedAt])
}

model SegufixSession {
  id             String      @id @default(cuid())
  ownerId        String
  slug           String?
  startTime      DateTime
  endTime        DateTime?
  durationMinutes Int?
  notes          String?
  moodBefore     MoodBefore?
  moodBeforeText String?
  moodAfter      MoodAfter?
  moodAfterText  String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  owner          User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  media          Media[]
  comments       SessionComment[]

  @@index([ownerId, startTime])
  @@index([slug])
}

model Album {
  id          String     @id @default(cuid())
  ownerId     String
  title       String
  description String?
  visibility  Visibility @default(PRIVATE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  owner       User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  media       Media[]
}

model Media {
  id          String     @id @default(cuid())
  ownerId     String
  albumId     String?
  sessionId   String?
  title       String
  kind        MediaKind
  url         String
  visibility  Visibility @default(PRIVATE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  owner       User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  album       Album?     @relation(fields: [albumId], references: [id], onDelete: SetNull)
  session     SegufixSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  comments    MediaComment[]

  @@index([sessionId])
}

model MediaComment {
  id        String   @id @default(cuid())
  mediaId   String
  ownerId   String
  body      String
  createdAt DateTime @default(now())
  media     Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([mediaId, createdAt])
  @@index([ownerId, createdAt])
}

model SessionComment {
  id        String         @id @default(cuid())
  sessionId String
  ownerId   String
  body      String
  createdAt DateTime       @default(now())
  session   SegufixSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  owner     User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([ownerId, createdAt])
}

model Event {
  id          String    @id @default(cuid())
  ownerId     String
  title       String
  location    String?
  startsAt    DateTime
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  owner       User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  checkIns    CheckIn[]
}

model CheckIn {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  note      String?
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model Message {
  id          String    @id @default(cuid())
  senderId    String
  recipientId String?
  body        String
  mediaUrl    String?
  createdAt   DateTime  @default(now())
  sender      User      @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient   User?     @relation("MessageRecipient", fields: [recipientId], references: [id], onDelete: SetNull)
}

model TelegramChat {
  id              String             @id @default(cuid())
  settingsId      String
  targetUserId    String?
  targetCircleId  String?
  chatId          String
  threadId        String?
  title           String?
  status          TelegramChatStatus @default(PENDING)
  lastMessageText String?
  lastMessageFrom String?
  lastMessageAt   DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  settings        UserSettings       @relation(fields: [settingsId], references: [id], onDelete: Cascade)
  targetUser      User?              @relation("TelegramChatTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetCircle    Circle?            @relation("TelegramChatTargetCircle", fields: [targetCircleId], references: [id], onDelete: SetNull)

  @@unique([settingsId, chatId, threadId])
  @@index([targetUserId])
  @@index([targetCircleId])
}

model TelegramUserMapping {
  id               String       @id @default(cuid())
  settingsId       String
  telegramUsername String
  appUserId        String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  settings         UserSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)
  appUser          User         @relation("TelegramMappedAppUser", fields: [appUserId], references: [id], onDelete: Cascade)

  @@unique([settingsId, telegramUsername])
  @@index([appUserId])
}
